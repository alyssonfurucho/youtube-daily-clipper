# Copie este arquivo para .streamlit/secrets.toml e preencha os valores.
# No Streamlit Community Cloud, configure os secrets pelo painel web (não faça commit deste arquivo preenchido).

# Não há secrets obrigatórios por padrão.
# Se quiser restringir o acesso ao app, adicione uma senha aqui:

# [auth]
# password = "sua_senha_aqui"
